def inverte_texto(texto):
    invertido = ''
    for letra in texto:
        invertido = letra + invertido
    return invertido    

def inverte_texto(texto):
    # Em Python, strings podem ser acessadas usando a sintaxe [início:fim:passo]
    # Ao omitir o 'início' e o 'fim' e definir o 'passo' como -1,
    # o Python inverte a string de forma extremamente eficiente.
    return texto[::-1]

# Exemplo de teste
resultado = inverte_texto("Python")
