    entrada = input("Digite a temperatura atual: ")
    
    # Converte o valor digitado para número decimal
    temperatura_atual = float(entrada)
    
    # Chama a função para verificar a temperatura
    verificar_temperatura(temperatura_atual)

except ValueError:
