# Função que verifica a temperatura
def verificar_temperatura(temp):
    # Verifica se a temperatura é maior que 30
    if temp > 30:
        # Exibe mensagem de alerta
        print("⚠️ " + "Alerta: Sistema em superaquecimento!")
    else:
        # Exibe mensagem de temperatura normal
        print("Temperatura " + "normal.")

try:
