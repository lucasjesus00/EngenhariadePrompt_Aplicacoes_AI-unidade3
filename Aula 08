import time  # Usado para simular intervalo entre verificações

# Define o limite crítico do sistema
LIMITE_CRITICO = 80

# Verifica se o valor ultrapassa o limite crítico
def verificar_condicao(valor):
    return valor > LIMITE_CRITICO

# Exibe alerta no console
def alerta_console(valor):
    print("⚠️ ALERTA CRÍTICO!")
    print("Valor detectado: " + str(valor))
    print("Estado: atenção necessária.")

# Simula envio de e-mail de alerta
def alerta_email(valor):
    print("\n📧 EMAIL SIMULADO")
    print("Destino: admin@sistema.com")
    print("Assunto: Alerta crítico")
    print("Mensagem: valor crítico detectado -> " + str(valor) + "\n")

# Função principal de monitoramento
def monitorar(valores):
    for valor in valores:
        print("\nMonitorando valor: " + str(valor))

        # Se condição crítica for atingida, dispara alertas
        if verificar_condicao(valor):
            alerta_console(valor)
            alerta_email(valor)
        else:
            print("Status normal.")

        # Simula intervalo entre verificações
        time.sleep(1)

# Lista simulando dados do sistema
dados = [45, 60, 72, 85, 90, 55, 100]

# Executa o monitoramento
monitorar(dados)
